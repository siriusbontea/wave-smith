# Wavesmith environment — copy to .env and adjust as needed.
# Every variable is optional; defaults (shown) target the standard local setup.

# ── App ──────────────────────────────────────────────────────────────────────

# Base URL of the ACE-Step REST API server (started by scripts/dev.sh).
#ENGINE_URL=http://127.0.0.1:8001

# Path to the engine checkout (cloned/pinned by scripts/setup.sh).
#ENGINE_DIR=./engine/ACE-Step-1.5

# LM the engine loads during warm-up. M0-verified: pass this explicitly —
# an empty warm-up call would later lazy-load the smaller 0.6B model instead.
#ENGINE_INIT_LM_MODEL=acestep-5Hz-lm-1.7B

# Runtime data root: SQLite db + generated audio live here (gitignored).
#DATA_DIR=./data

# Port for the Next.js app (dev and prod). The app binds 127.0.0.1 only.
#PORT=3000

# Absolute path to demucs (optional). setup.sh installs via uv to ~/.local/bin/demucs.
#DEMUCS_BIN=/Users/you/.local/bin/demucs

# Absolute path to basic-pitch (optional). setup.sh installs via uv to ~/.local/bin/basic-pitch.
#BASIC_PITCH_BIN=/Users/you/.local/bin/basic-pitch

# Set to 1 to swap in the mock engine (instant canned responses; powers the
# test suite and demo mode — tour the UI without installing the engine).
#MOCK_ENGINE=0

# ── Optional lyrics LLM (Ollama) ─────────────────────────────────────────────
# Wavesmith applies no content filtering to lyrics. The engine's built-in
# planner handled explicit lyrics fine in M0 testing, but a dedicated local
# LLM writes better lyrics. When Ollama isn't running, the Generate Lyrics
# button hides and everything else works.

# Ollama endpoint.
#LYRICS_LLM_URL=http://localhost:11434

# Ollama model tag for lyric writing. Default is the ~5 GB Dolphin 3.0 8B
# (uncensored, instruction-steerable — fits beside the engine in 32 GB RAM).
# Any instruct model you already have works (e.g. qwen3:8b). On ≥48 GB
# machines, TheDrummer's Cydonia 24B is a notable quality upgrade for
# creative writing — avoid running models this large concurrently with
# generation on 32 GB.
#LYRICS_MODEL=dolphin3:8b

# ── Engine passthroughs (set by scripts/dev.sh when launching the engine) ────
# These matter on Apple Silicon (M0-verified, see docs/ENGINE_NOTES.md §8):
#   ACESTEP_LM_BACKEND=mlx          native Apple Silicon LM inference
#   TOKENIZERS_PARALLELISM=false    silences a harmless warning
#   ACESTEP_GENERATION_TIMEOUT=600  raise for very long renders (seconds)
#   ACESTEP_TMPDIR=                 engine scratch/audio dir (default: engine/.cache)
# Do NOT set ACESTEP_CHECKPOINTS_DIR — the engine honors it inconsistently
# (double-download risk; see DECISIONS.md).
